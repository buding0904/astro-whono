---
import AdminHomeSection from '../../components/admin/AdminHomeSection.astro';
import AdminPageSection from '../../components/admin/AdminPageSection.astro';
import AdminSidebarSection from '../../components/admin/AdminSidebarSection.astro';
import AdminSiteSection from '../../components/admin/AdminSiteSection.astro';
import AdminUiSection from '../../components/admin/AdminUiSection.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEditableThemeSettingsPayload, type SidebarNavId } from '../../lib/theme-settings';
import {
  ADMIN_FOOTER_START_YEAR_MIN,
  ADMIN_HOME_INTRO_MAX_LENGTH,
  ADMIN_NAV_IDS,
  ADMIN_PAGE_SUBTITLE_MAX_LENGTH,
  ADMIN_SOCIAL_CUSTOM_LIMIT,
  getAdminFooterStartYearMax
} from '../../lib/admin-console/shared';
import { createWithBase } from '../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const settingsEndpoint = withBase('/api/admin/settings/');

const navIdOrder: readonly SidebarNavId[] = ADMIN_NAV_IDS;
const navLabelFallback: Record<SidebarNavId, string> = {
  essay: '随笔',
  bits: '絮语',
  memo: '小记',
  archive: '归档',
  about: '关于'
};
const homeIntroMaxLength = ADMIN_HOME_INTRO_MAX_LENGTH;
const pageSubtitleMaxLength = ADMIN_PAGE_SUBTITLE_MAX_LENGTH;
const footerStartYearMin = ADMIN_FOOTER_START_YEAR_MIN;
const footerStartYearMax = getAdminFooterStartYearMax();
const socialCustomLimit = ADMIN_SOCIAL_CUSTOM_LIMIT;

const initialPayload = getEditableThemeSettingsPayload();
const initialNavMap = new Map(
  initialPayload.settings.shell.nav.map((item) => [item.id, item])
);

const initialPayloadWithFallbackNav = {
  settings: {
    ...initialPayload.settings,
    shell: {
      ...initialPayload.settings.shell,
      nav: navIdOrder.map((id, index) => {
        const current = initialNavMap.get(id);
        if (current) return current;
        return {
          id,
          label: navLabelFallback[id],
          visible: true,
          order: index + 1
        };
      })
    }
  },
  sources: initialPayload.sources
};

const bootstrapJson = JSON.stringify(initialPayloadWithFallbackNav).replace(/</g, '\u003c');
---

<BaseLayout title="Theme Console" bodyClass="admin-page">
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  {
    isDev ? (
      <section class="admin-console" data-admin-root data-settings-endpoint={settingsEndpoint}>
        <header class="page-header page-header--admin">
          <div class="admin-heading">
            <h1 class="page-title">Theme Console</h1>
            <span class="page-subtitle">主题设置</span>
          </div>
          <p id="admin-status" class="admin-status" data-state="idle">等待加载</p>
        </header>

        <p id="admin-error-banner" class="admin-banner admin-banner--error" hidden></p>

        <form id="admin-form" class="admin-form" novalidate>
          <AdminSiteSection
            footerStartYearMin={footerStartYearMin}
            footerStartYearMax={footerStartYearMax}
            socialCustomLimit={socialCustomLimit}
          />

          <AdminSidebarSection navIdOrder={navIdOrder} />

          <AdminHomeSection homeIntroMaxLength={homeIntroMaxLength} />

          <AdminPageSection pageSubtitleMaxLength={pageSubtitleMaxLength} />

          <AdminUiSection />
        </form>

        <div class="admin-actions">
          <p id="admin-dirty-banner" class="admin-banner admin-banner--dirty" hidden aria-live="polite">
            * 你有未保存更改，离开页面会触发提醒。
          </p>
          <div class="admin-actions__buttons">
            <button id="admin-validate" class="admin-btn" type="button">检查配置</button>
            <button id="admin-reset" class="admin-btn admin-btn--ghost" type="button">重置更改</button>
            <button id="admin-save" class="admin-btn admin-btn--muted" type="button">保存</button>
          </div>
        </div>

        <script id="admin-bootstrap" type="application/json" is:inline set:html={bootstrapJson}></script>
      </section>
    ) : (
      <section class="admin-console admin-console--readonly">
        <header class="page-header page-header--admin">
          <div class="admin-heading">
            <h1 class="page-title">Theme Console</h1>
            <span class="page-subtitle">主题设置</span>
          </div>
        </header>
        <p class="admin-hint">
          当前页面仅用于本地开发配置。根据 Phase 1 边界，生产环境不提供可写后台。
        </p>
      </section>
    )
  }

  {
    isDev ? (
      <script>
        import '../../scripts/admin-console/index.ts';
      </script>
    ) : null
  }
</BaseLayout>

